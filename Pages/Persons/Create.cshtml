@page
@model LandRegistrySystem.Pages.Persons.CreateModel
@{
    ViewData["Title"] = "ثبت شخص جدید";
}

<div class="container mt-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>ثبت شخص جدید</h1>
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i> بازگشت به لیست
                </a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <form method="post" id="personForm">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <!-- ========================================== -->
                        <!-- جستجوی کدملی -->
                        <!-- ========================================== -->
                        <div class="card mb-3 border-primary">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="fas fa-search"></i> جستجوی شخص</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Person.NationalCode" class="form-label fw-bold">
                                                <i class="fas fa-id-card"></i> کدملی
                                            </label>
                                            <input asp-for="Person.NationalCode" class="form-control" 
                                                   id="NationalCode" placeholder="کدملی را وارد کنید..." />
                                            <span asp-validation-for="Person.NationalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">
                                                پس از وارد کردن کدملی، اطلاعات به طور خودکار جستجو می‌شود
                                            </small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div id="searchResult" class="mt-3">
                                            @if (Model.IsPersonFound && Model.FoundPerson != null)
                                            {
                                                <div class="alert alert-success">
                                                    <i class="fas fa-check-circle"></i> 
                                                    <strong>شخص یافت شد</strong>
                                                    <ul class="mb-0 mt-2" style="list-style:none; padding-right:0;">
                                                        <li><strong>نام:</strong> @Model.FoundPerson.FirstName</li>
                                                        <li><strong>نام خانوادگی:</strong> @Model.FoundPerson.LastName</li>
                                                        <li><strong>کدملی:</strong> @Model.FoundPerson.NationalCode</li>
                                                        <li><strong>شماره همراه:</strong> @Model.FoundPerson.Mobile</li>
                                                        <li><strong>آدرس:</strong> @Model.FoundPerson.Address</li>
                                                    </ul>
                                                </div>
                                            }
                                            else if (!string.IsNullOrEmpty(Model.SearchNationalCode))
                                            {
                                                <div class="alert alert-warning">
                                                    <i class="fas fa-exclamation-triangle"></i> 
                                                    شخصی با این کدملی یافت نشد
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- اطلاعات هویتی -->
                        <!-- ========================================== -->
                        <div class="card mb-3 border-success">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-id-card"></i> اطلاعات هویتی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.FirstName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام
                                            </label>
                                            <input asp-for="Person.FirstName" class="form-control" id="FirstName" />
                                            <span asp-validation-for="Person.FirstName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.LastName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام خانوادگی
                                            </label>
                                            <input asp-for="Person.LastName" class="form-control" id="LastName" />
                                            <span asp-validation-for="Person.LastName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.FatherName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام پدر
                                            </label>
                                            <input asp-for="Person.FatherName" class="form-control" id="FatherName" />
                                            <span asp-validation-for="Person.FatherName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.BirthDate" class="form-label fw-bold">
                                                <i class="fas fa-calendar-alt"></i> تاریخ تولد
                                            </label>
                                            <input asp-for="Person.BirthDate" class="form-control" type="date" />
                                            <span asp-validation-for="Person.BirthDate" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- اطلاعات تماس -->
                        <!-- ========================================== -->
                        <div class="card mb-3 border-info">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="fas fa-phone"></i> اطلاعات تماس</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.Mobile" class="form-label fw-bold">
                                                <i class="fas fa-mobile-alt"></i> شماره همراه
                                            </label>
                                            <input asp-for="Person.Mobile" class="form-control" id="Mobile" />
                                            <span asp-validation-for="Person.Mobile" class="text-danger"></span>
                                            <small class="form-text text-muted">مثال: 09123456789</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.Phone" class="form-label fw-bold">
                                                <i class="fas fa-phone"></i> شماره تلفن ثابت
                                            </label>
                                            <input asp-for="Person.Phone" class="form-control" id="Phone" />
                                            <span asp-validation-for="Person.Phone" class="text-danger"></span>
                                            <small class="form-text text-muted">تلفن ثابت</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Person.Email" class="form-label fw-bold">
                                                <i class="fas fa-envelope"></i> ایمیل
                                            </label>
                                            <input asp-for="Person.Email" class="form-control" id="Email" type="email" />
                                            <span asp-validation-for="Person.Email" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- اطلاعات مکانی -->
                        <!-- ========================================== -->
                        <div class="card mb-3 border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h5 class="mb-0"><i class="fas fa-map-marker-alt"></i> اطلاعات مکانی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="mb-3">
                                            <label asp-for="Person.Address" class="form-label fw-bold">
                                                <i class="fas fa-home"></i> آدرس
                                            </label>
                                            <textarea asp-for="Person.Address" class="form-control" id="Address" rows="3"></textarea>
                                            <span asp-validation-for="Person.Address" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 500 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Person.PostalCode" class="form-label fw-bold">
                                                <i class="fas fa-mail-bulk"></i> کد پستی
                                            </label>
                                            <input asp-for="Person.PostalCode" class="form-control" id="PostalCode" />
                                            <span asp-validation-for="Person.PostalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- دکمه‌ها -->
                        <!-- ========================================== -->
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-page="./Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-right"></i> بازگشت
                            </a>
                            <button type="submit" class="btn btn-success" id="submitBtn">
                                <i class="fas fa-save"></i> ثبت شخص
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/person-validation.js"></script>
}