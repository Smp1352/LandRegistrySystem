@page
@using LandRegistrySystem.Models.Enums
@model LandRegistrySystem.Pages.Parcels.CreateModel
@{
    ViewData["Title"] = "ثبت قطعه جدید";
}

<div class="container mt-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>ثبت قطعه جدید</h1>
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i> بازگشت به لیست
                </a>
            </div>

            <!-- ✅ نمایش پیام‌ها -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <!-- ✅ فرم با enctype (برای فایل‌ها) -->
                    <form method="post" id="parcelForm">
                        <!-- ✅ نمایش خلاصه خطاها -->
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <!-- ========================================== -->
                        <!-- بخش 1: اطلاعات توصیفی TDB -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-success">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-database"></i> مشخصات TDB - اطلاعات توصیفی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.X" class="form-label fw-bold">مختصات X</label>
                                            <input asp-for="Parcel.X" class="form-control" />
                                            <span asp-validation-for="Parcel.X" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Y" class="form-label fw-bold">مختصات Y</label>
                                            <input asp-for="Parcel.Y" class="form-control" />
                                            <span asp-validation-for="Parcel.Y" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Zone" class="form-label fw-bold">زون</label>
                                            <input asp-for="Parcel.Zone" class="form-control" />
                                            <span asp-validation-for="Parcel.Zone" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.ParcelCode" class="form-label fw-bold">کد قطعه</label>
                                            <input asp-for="Parcel.ParcelCode" class="form-control" />
                                            <span asp-validation-for="Parcel.ParcelCode" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 20 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PostalCode" class="form-label fw-bold">کدپستی</label>
                                            <input asp-for="Parcel.PostalCode" class="form-control" />
                                            <span asp-validation-for="Parcel.PostalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Area" class="form-label fw-bold">مساحت (مترمربع)</label>
                                            <input asp-for="Parcel.Area" class="form-control" step="0.01" />
                                            <span asp-validation-for="Parcel.Area" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد مثبت</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.UniqueParcelCode" class="form-label fw-bold">کد یکتا</label>
                                            <input asp-for="Parcel.UniqueParcelCode" class="form-control" />
                                            <span asp-validation-for="Parcel.UniqueParcelCode" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Province" class="form-label fw-bold">استان</label>
                                            <input asp-for="Parcel.Province" class="form-control" />
                                            <span asp-validation-for="Parcel.Province" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Shahrestan" class="form-label fw-bold">شهرستان</label>
                                            <input asp-for="Parcel.Shahrestan" class="form-control" />
                                            <span asp-validation-for="Parcel.Shahrestan" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.AbadiName" class="form-label fw-bold">نام آبادی</label>
                                            <input asp-for="Parcel.AbadiName" class="form-control" />
                                            <span asp-validation-for="Parcel.AbadiName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.AbadiCode" class="form-label fw-bold">کد آبادی</label>
                                            <input asp-for="Parcel.AbadiCode" class="form-control" />
                                            <span asp-validation-for="Parcel.AbadiCode" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد معتبر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 2: اطلاعات ثبتی -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-info">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="fas fa-gavel"></i> اطلاعات ثبتی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.NahiyeSabti" class="form-label fw-bold">ناحیه ثبتی</label>
                                            <input asp-for="Parcel.NahiyeSabti" class="form-control" />
                                            <span asp-validation-for="Parcel.NahiyeSabti" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakName" class="form-label fw-bold">نام پلاک</label>
                                            <input asp-for="Parcel.PlakName" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakAsli" class="form-label fw-bold">پلاک اصلی</label>
                                            <input asp-for="Parcel.PlakAsli" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakAsli" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 5 رقم</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakFarei" class="form-label fw-bold">پلاک فرعی</label>
                                            <input asp-for="Parcel.PlakFarei" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakFarei" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.BakhshSabti" class="form-label fw-bold">بخش ثبتی</label>
                                            <input asp-for="Parcel.BakhshSabti" class="form-control" />
                                            <span asp-validation-for="Parcel.BakhshSabti" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 5 رقم</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.CurrentOperationLandUse" class="form-label fw-bold">بهره برداری فعلی</label>
                                            <select asp-for="Parcel.CurrentOperationLandUse" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <optgroup label="زراعت">
                                                    <option value="زراعت آبی">زراعت آبی</option>
                                                    <option value="زراعت دیم">زراعت دیم</option>
                                                </optgroup>
                                                <optgroup label="باغ">
                                                    <option value="باغ آبی">باغ آبی</option>
                                                    <option value="باغ دیم">باغ دیم</option>
                                                </optgroup>
                                                <optgroup label="نهالستان">
                                                    <option value="نهالستان / قلمستان">نهالستان / قلمستان</option>
                                                </optgroup>
                                                <optgroup label="پرورش">
                                                    <option value="پرورش طویل">پرورش طویل</option>
                                                    <option value="آبی‌پوری">آبی‌پوری</option>
                                                </optgroup>
                                                <optgroup label="صنایع">
                                                    <option value="صنایع تبدیلی و تکمیلی">صنایع تبدیلی و تکمیلی</option>
                                                </optgroup>
                                                <optgroup label="محصولات">
                                                    <option value="نوع محصول محصوالت">نوع محصول محصوالت</option>
                                                </optgroup>
                                            </select>
                                            <span asp-validation-for="Parcel.CurrentOperationLandUse" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.CropsType" class="form-label fw-bold">نوع محصول</label>
                                            <input asp-for="Parcel.CropsType" class="form-control" />
                                            <span asp-validation-for="Parcel.CropsType" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 3: اطلاعات مالک -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h5 class="mb-0"><i class="fas fa-user"></i> اطلاعات مالک</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerNationalCode" class="form-label fw-bold">کدملی مالک</label>
                                            <div class="input-group">
                                                <input asp-for="Parcel.OwnerNationalCode" class="form-control" id="OwnerNationalCode" />
                                                <button type="button" class="btn btn-primary" onclick="searchOwner()">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                            </div>
                                            <span asp-validation-for="Parcel.OwnerNationalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6" id="ownerResult">
                                        <!-- نتیجه جستجو -->
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerName" class="form-label fw-bold">نام</label>
                                            <input asp-for="Parcel.OwnerName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerLastName" class="form-label fw-bold">نام خانوادگی</label>
                                            <input asp-for="Parcel.OwnerLastName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerLastName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerMobile" class="form-label fw-bold">شماره همراه</label>
                                            <input asp-for="Parcel.OwnerMobile" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerMobile" class="text-danger"></span>
                                            <small class="form-text text-muted">مثال: 09123456789</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerFatherName" class="form-label fw-bold">نام پدر</label>
                                            <input asp-for="Parcel.OwnerFatherName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerFatherName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerBirthdayPersian" class="form-label fw-bold">تاریخ تولد</label>
                                            <input asp-for="Parcel.OwnerBirthdayPersian" class="form-control persian-datepicker" />
                                            <span asp-validation-for="Parcel.OwnerBirthdayPersian" class="text-danger"></span>
                                            <small class="form-text text-muted">فرمت: yyyy/MM/dd</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerType" class="form-label fw-bold">نوع متصرف</label>
                                            <select asp-for="Parcel.OwnerType" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <option value="@OwnerType.Natural">حقیقی</option>
                                                <option value="@OwnerType.Legal">حقوقی</option>
                                            </select>
                                            <span asp-validation-for="Parcel.OwnerType" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipUnit" class="form-label fw-bold">نوع مالکیت</label>
                                            <select asp-for="Parcel.OwnershipUnit" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <option value="@OwnershipUnit.Land">عرصه</option>
                                                <option value="@OwnershipUnit.Building">اعیان</option>
                                                <option value="@OwnershipUnit.LandAndBuilding">عرصه و اعیان</option>
                                            </select>
                                            <span asp-validation-for="Parcel.OwnershipUnit" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.ShorakaTedad" class="form-label fw-bold">تعداد شرکا</label>
                                            <input asp-for="Parcel.ShorakaTedad" class="form-control" />
                                            <span asp-validation-for="Parcel.ShorakaTedad" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipQuantity" class="form-label fw-bold">تعداد سهم</label>
                                            <input asp-for="Parcel.OwnershipQuantity" class="form-control" step="0.01" />
                                            <span asp-validation-for="Parcel.OwnershipQuantity" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد مثبت</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipProof" class="form-label fw-bold">ادله و امارات مالکیت</label>
                                            <input asp-for="Parcel.OwnershipProof" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnershipProof" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 500 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 4: اطلاعات بهره‌بردار -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-secondary">
                            <div class="card-header bg-secondary text-white">
                                <h5 class="mb-0"><i class="fas fa-user-tie"></i> اطلاعات بهره‌بردار</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorNationalCode" class="form-label fw-bold">کدملی بهره‌بردار</label>
                                            <div class="input-group">
                                                <input asp-for="Parcel.OperatorNationalCode" class="form-control" id="OperatorNationalCode" />
                                                <button type="button" class="btn btn-primary" onclick="searchOperator()">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                            </div>
                                            <span asp-validation-for="Parcel.OperatorNationalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6" id="operatorResult">
                                        <!-- نتیجه جستجو -->
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorName" class="form-label fw-bold">نام</label>
                                            <input asp-for="Parcel.OperatorName" class="form-control" />
                                            <span asp-validation-for="Parcel.OperatorName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorLastName" class="form-label fw-bold">نام خانوادگی</label>
                                            <input asp-for="Parcel.OperatorLastName" class="form-control" />
                                            <span asp-validation-for="Parcel.OperatorLastName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorMobile" class="form-label fw-bold">شماره همراه</label>
                                            <input asp-for="Parcel.OperatorMobile" class="form-control" />
                                            <span asp-validation-for="Parcel.OperatorMobile" class="text-danger"></span>
                                            <small class="form-text text-muted">مثال: 09123456789</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorFatherName" class="form-label fw-bold">نام پدر</label>
                                            <input asp-for="Parcel.OperatorFatherName" class="form-control" />
                                            <span asp-validation-for="Parcel.OperatorFatherName" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OperatorBirthdayPersian" class="form-label fw-bold">تاریخ تولد</label>
                                            <input asp-for="Parcel.OperatorBirthdayPersian" class="form-control persian-datepicker" />
                                            <span asp-validation-for="Parcel.OperatorBirthdayPersian" class="text-danger"></span>
                                            <small class="form-text text-muted">فرمت: yyyy/MM/dd</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.RelationOwnerOperator" class="form-label fw-bold">رابطه با مالک</label>
                                            <input asp-for="Parcel.RelationOwnerOperator" class="form-control" />
                                            <span asp-validation-for="Parcel.RelationOwnerOperator" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipConfirm" class="form-label fw-bold">روش احراز تصرفات</label>
                                            <input asp-for="Parcel.OwnershipConfirm" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnershipConfirm" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 5: سایر اطلاعات -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-dark">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0"><i class="fas fa-cogs"></i> سایر اطلاعات</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.ChangeLandUse" class="form-label fw-bold">کاربری غیرکشاورزی</label>
                                            <input asp-for="Parcel.ChangeLandUse" class="form-control" />
                                            <span asp-validation-for="Parcel.ChangeLandUse" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 10 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.SanadMafroozi" class="form-label fw-bold">سند مفروزی</label>
                                            <select asp-for="Parcel.SanadMafroozi" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <option value="بله">بله</option>
                                                <option value="خیر">خیر</option>
                                            </select>
                                            <span asp-validation-for="Parcel.SanadMafroozi" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Description" class="form-label fw-bold">توضیحات</label>
                                            <textarea asp-for="Parcel.Description" class="form-control" rows="2"></textarea>
                                            <span asp-validation-for="Parcel.Description" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 254 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- دکمه‌ها -->
                        <!-- ========================================== -->
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-page="./Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-right"></i> بازگشت
                            </a>
                            <button type="submit" class="btn btn-success" id="submitBtn">
                                <i class="fas fa-save"></i> ثبت قطعه
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/persian-date.js"></script>
    <script>
        // ==========================================
        // جستجوی مالک
        // ==========================================
        function searchOwner() {
        var nationalCode = document.getElementById('OwnerNationalCode').value.trim();
        if (!nationalCode || nationalCode.length !== 10) {
        alert('لطفاً کدملی 10 رقمی را وارد کنید');
        return;
        }

        $.ajax({
        url: './Create?handler=SearchPerson',
        type: 'GET',
        data: { nationalCode: nationalCode },
        success: function(response) {
        if (response.exists) {
        document.querySelector('#Parcel_OwnerName').value = response.firstName;
        document.querySelector('#Parcel_OwnerLastName').value = response.lastName;
        document.querySelector('#Parcel_OwnerMobile').value = response.mobile;
        document.querySelector('#Parcel_OwnerFatherName').value = response.fatherName;
        document.querySelector('#Parcel_OwnerBirthdayPersian').value = response.birthDatePersian;

        document.getElementById('ownerResult').innerHTML =
        '<div class="alert alert-success">' +
        '<i class="fas fa-check-circle"></i> شخص یافت شد: ' + response.firstName + ' ' + response.lastName +
        '</div>';
        } else {
        document.getElementById('ownerResult').innerHTML =
        '<div class="alert alert-warning">' +
        '<i class="fas fa-exclamation-triangle"></i> ' + response.message +
        ' <a href="/Persons/Create?returnUrl=' + encodeURIComponent(window.location.pathname) +
        '" class="btn btn-sm btn-success">ثبت شخص جدید</a>' +
        '</div>';
        }
        },
        error: function() {
        document.getElementById('ownerResult').innerHTML =
        '<div class="alert alert-danger">خطا در ارتباط با سرور</div>';
        }
        });
        }

        // ==========================================
        // جستجوی بهره‌بردار
        // ==========================================
        function searchOperator() {
        var nationalCode = document.getElementById('OperatorNationalCode').value.trim();
        if (!nationalCode || nationalCode.length !== 10) {
        alert('لطفاً کدملی 10 رقمی را وارد کنید');
        return;
        }

        $.ajax({
        url: './Create?handler=SearchPerson',
        type: 'GET',
        data: { nationalCode: nationalCode },
        success: function(response) {
        if (response.exists) {
        document.querySelector('#Parcel_OperatorName').value = response.firstName;
        document.querySelector('#Parcel_OperatorLastName').value = response.lastName;
        document.querySelector('#Parcel_OperatorMobile').value = response.mobile;
        document.querySelector('#Parcel_OperatorFatherName').value = response.fatherName;
        document.querySelector('#Parcel_OperatorBirthdayPersian').value = response.birthDatePersian;

        document.getElementById('operatorResult').innerHTML =
        '<div class="alert alert-success">' +
        '<i class="fas fa-check-circle"></i> شخص یافت شد: ' + response.firstName + ' ' + response.lastName +
        '</div>';
        } else {
        document.getElementById('operatorResult').innerHTML =
        '<div class="alert alert-warning">' +
        '<i class="fas fa-exclamation-triangle"></i> ' + response.message +
        ' <a href="/Persons/Create?returnUrl=' + encodeURIComponent(window.location.pathname) +
        '" class="btn btn-sm btn-success">ثبت شخص جدید</a>' +
        '</div>';
        }
        },
        error: function() {
        document.getElementById('operatorResult').innerHTML =
        '<div class="alert alert-danger">خطا در ارتباط با سرور</div>';
        }
        });
        }

        // ==========================================
        // جستجو با Enter
        // ==========================================
        document.getElementById('OwnerNationalCode').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
        e.preventDefault();
        searchOwner();
        }
        });

        document.getElementById('OperatorNationalCode').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
        e.preventDefault();
        searchOperator();
        }
        });
    </script>
}