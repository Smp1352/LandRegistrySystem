@page
@model LandRegistrySystem.Pages.Parcels.CreateModel
@{
    ViewData["Title"] = "ثبت قطعه جدید";
}

<div class="container mt-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>ثبت قطعه جدید</h1>
                <a asp-page="./Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i> بازگشت به لیست
                </a>
            </div>
            <!-- ========================================== -->
            <!-- جستجوی شخص با کدملی -->
            <!-- ========================================== -->
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user-search"></i> جستجوی شخص</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">کدملی شخص</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" 
                                           id="nationalCodeSearch" 
                                           placeholder="کدملی را وارد کنید..."
                                           value="@Model.SearchNationalCode" />
                                    <button class="btn btn-primary" type="button" onclick="searchPerson()">
                                        <i class="fas fa-search"></i> جستجو
                                    </button>
                                    <a asp-page="./Create" class="btn btn-success">
                                        <i class="fas fa-plus"></i> ثبت شخص جدید
                                    </a>
                                </div>
                                <small class="form-text text-muted">
                                    برای جستجو، کدملی را وارد کرده و دکمه جستجو را بزنید
                                </small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            @if (Model.SelectedPerson != null)
                            {
                                <div class="alert alert-success">
                                    <h6><i class="fas fa-check-circle"></i> شخص یافت شد</h6>
                                    <hr />
                                    <div class="row">
                                        <div class="col-6">
                                            <strong>نام:</strong> @Model.SelectedPerson.FirstName
                                        </div>
                                        <div class="col-6">
                                            <strong>نام خانوادگی:</strong> @Model.SelectedPerson.LastName
                                        </div>
                                        <div class="col-6">
                                            <strong>کدملی:</strong> @Model.SelectedPerson.NationalCode
                                        </div>
                                        <div class="col-6">
                                            <strong>شماره همراه:</strong> @Model.SelectedPerson.Mobile
                                        </div>
                                        <div class="col-12">
                                            <strong>آدرس:</strong> @Model.SelectedPerson.Address
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(Model.SearchNationalCode))
                            {
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    شخصی با این کدملی یافت نشد. لطفاً ابتدا شخص را <a asp-page="/Persons/Create" class="alert-link">ثبت</a> کنید.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <script>
                function searchPerson() {
                    var nationalCode = document.getElementById('nationalCodeSearch').value.trim();
                    if (nationalCode) {
                        window.location.href = './Create?nationalCode=' + encodeURIComponent(nationalCode);
                    } else {
                        alert('لطفاً کدملی را وارد کنید');
                    }
                }
            </script> 

            <!-- ========================================== -->
            <!-- پیام موفقیت -->
            <!-- ========================================== -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <form method="post" id="parcelForm">
                        <!-- ========================================== -->
                        <!-- نمایش خلاصه خطاها -->
                        <!-- ========================================== -->
                        <div asp-validation-summary="All" class="alert alert-danger" style="display:none;" id="validationSummary">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>لطفاً خطاهای زیر را اصلاح کنید:</span>
                            <ul id="validationSummaryList"></ul>
                        </div>

                        
                        <!-- ========================================== -->
                        <!-- بخش 2: اطلاعات توصیفی TDB -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-success">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-database"></i> مشخصات TDB - اطلاعات توصیفی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.X" class="form-label fw-bold">
                                                <i class="fas fa-coordinates"></i> مختصات X مرکز قطعه
                                            </label>
                                            <input asp-for="Parcel.X" class="form-control" />
                                            <span asp-validation-for="Parcel.X" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Y" class="form-label fw-bold">
                                                <i class="fas fa-coordinates"></i> مختصات Y مرکز قطعه
                                            </label>
                                            <input asp-for="Parcel.Y" class="form-control" />
                                            <span asp-validation-for="Parcel.Y" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Zone" class="form-label fw-bold">
                                                <i class="fas fa-map-pin"></i> زون مرکز قطعه
                                            </label>
                                            <input asp-for="Parcel.Zone" class="form-control" />
                                            <span asp-validation-for="Parcel.Zone" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.ParcelCode" class="form-label fw-bold">
                                                <i class="fas fa-barcode"></i> کد قطعه
                                            </label>
                                            <input asp-for="Parcel.ParcelCode" class="form-control" />
                                            <span asp-validation-for="Parcel.ParcelCode" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 20 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PostalCode" class="form-label fw-bold">
                                                <i class="fas fa-mail-bulk"></i> کدپستی قطعه
                                            </label>
                                            <input asp-for="Parcel.PostalCode" class="form-control" />
                                            <span asp-validation-for="Parcel.PostalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Area" class="form-label fw-bold">
                                                <i class="fas fa-ruler-combined"></i> مساحت (مترمربع)
                                            </label>
                                            <input asp-for="Parcel.Area" class="form-control" step="0.01" />
                                            <span asp-validation-for="Parcel.Area" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد مثبت</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.UniqueParcelCode" class="form-label fw-bold">
                                                <i class="fas fa-id-card"></i> کد شناسه یکتای قطعه
                                            </label>
                                            <input asp-for="Parcel.UniqueParcelCode" class="form-control" />
                                            <span asp-validation-for="Parcel.UniqueParcelCode" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Province" class="form-label fw-bold">
                                                <i class="fas fa-city"></i> استان
                                            </label>
                                            <input asp-for="Parcel.Province" class="form-control" />
                                            <span asp-validation-for="Parcel.Province" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.Shahrestan" class="form-label fw-bold">
                                                <i class="fas fa-map-marked-alt"></i> شهرستان
                                            </label>
                                            <input asp-for="Parcel.Shahrestan" class="form-control" />
                                            <span asp-validation-for="Parcel.Shahrestan" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.AbadiName" class="form-label fw-bold">
                                                <i class="fas fa-home"></i> نام آبادی
                                            </label>
                                            <input asp-for="Parcel.AbadiName" class="form-control" />
                                            <span asp-validation-for="Parcel.AbadiName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.AbadiCode" class="form-label fw-bold">
                                                <i class="fas fa-hashtag"></i> کد آبادی
                                            </label>
                                            <input asp-for="Parcel.AbadiCode" class="form-control" />
                                            <span asp-validation-for="Parcel.AbadiCode" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد معتبر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 3: اطلاعات ثبتی -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-info">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="fas fa-gavel"></i> اطلاعات ثبتی</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.NahiyeSabti" class="form-label fw-bold">
                                                <i class="fas fa-landmark"></i> ناحیه ثبتی
                                            </label>
                                            <input asp-for="Parcel.NahiyeSabti" class="form-control" />
                                            <span asp-validation-for="Parcel.NahiyeSabti" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakName" class="form-label fw-bold">
                                                <i class="fas fa-file-signature"></i> نام پلاک ثبتی
                                            </label>
                                            <input asp-for="Parcel.PlakName" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakAsli" class="form-label fw-bold">
                                                <i class="fas fa-sort-numeric-up"></i> شماره پلاک اصلی
                                            </label>
                                            <input asp-for="Parcel.PlakAsli" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakAsli" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 5 رقم</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.PlakFarei" class="form-label fw-bold">
                                                <i class="fas fa-sort-numeric-down"></i> شماره پلاک فرعی
                                            </label>
                                            <input asp-for="Parcel.PlakFarei" class="form-control" />
                                            <span asp-validation-for="Parcel.PlakFarei" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 10 رقم</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.BakhshSabti" class="form-label fw-bold">
                                                <i class="fas fa-building"></i> بخش ثبتی
                                            </label>
                                            <input asp-for="Parcel.BakhshSabti" class="form-control" />
                                            <span asp-validation-for="Parcel.BakhshSabti" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 5 رقم</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.CurrentOperationLandUse" class="form-label fw-bold">
                                                <i class="fas fa-tractor"></i> بهره برداری فعلی قطعه
                                            </label>
                                            <select asp-for="Parcel.CurrentOperationLandUse" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <optgroup label="زراعت">
                                                    <option value="زراعت آبی">زراعت آبی</option>
                                                    <option value="زراعت دیم">زراعت دیم</option>
                                                </optgroup>
                                                <optgroup label="باغ">
                                                    <option value="باغ آبی">باغ آبی</option>
                                                    <option value="باغ دیم">باغ دیم</option>
                                                </optgroup>
                                                <optgroup label="نهالستان">
                                                    <option value="نهالستان / قلمستان">نهالستان / قلمستان</option>
                                                </optgroup>
                                                <optgroup label="پرورش">
                                                    <option value="پرورش طویل">پرورش طویل</option>
                                                    <option value="آبی‌پوری">آبی‌پوری</option>
                                                </optgroup>
                                                <optgroup label="صنایع">
                                                    <option value="صنایع تبدیلی و تکمیلی">صنایع تبدیلی و تکمیلی</option>
                                                </optgroup>
                                                <optgroup label="محصولات">
                                                    <option value="نوع محصول محصوالت">نوع محصول محصوالت</option>
                                                </optgroup>
                                            </select>
                                            <span asp-validation-for="Parcel.CurrentOperationLandUse" class="text-danger"></span>
                                            <small class="form-text text-muted">نوع بهره برداری فعلی قطعه را انتخاب کنید</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.CropsType" class="form-label fw-bold">
                                                <i class="fas fa-seedling"></i> نوع محصول
                                            </label>
                                            <input asp-for="Parcel.CropsType" class="form-control" />
                                            <span asp-validation-for="Parcel.CropsType" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 4: اطلاعات مالک (متصرف) -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h5 class="mb-0"><i class="fas fa-user"></i> اطلاعات مالک (متصرف)</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerType" class="form-label fw-bold">
                                                <i class="fas fa-user-tag"></i> نوع متصرف
                                            </label>
                                            <select asp-for="Parcel.OwnerType" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <option value="حقیقی">حقیقی</option>
                                                <option value="حقوقی">حقوقی</option>
                                            </select>
                                            <span asp-validation-for="Parcel.OwnerType" class="text-danger"></span>
                                            <small class="form-text text-muted">نوع شخص متصرف را انتخاب کنید</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.ShorakaTedad" class="form-label fw-bold">
                                                <i class="fas fa-users"></i> تعداد شرکا
                                            </label>
                                            <input asp-for="Parcel.ShorakaTedad" class="form-control" />
                                            <span asp-validation-for="Parcel.ShorakaTedad" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 10 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerLastName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام خانوادگی متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerLastName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerLastName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerNationalCode" class="form-label fw-bold">
                                                <i class="fas fa-id-card"></i> کدملی متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerNationalCode" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerNationalCode" class="text-danger"></span>
                                            <small class="form-text text-muted">10 رقم</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerMobile" class="form-label fw-bold">
                                                <i class="fas fa-phone"></i> شماره همراه متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerMobile" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerMobile" class="text-danger"></span>
                                            <small class="form-text text-muted">مثال: 09123456789</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerFatherName" class="form-label fw-bold">
                                                <i class="fas fa-user"></i> نام پدر متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerFatherName" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnerFatherName" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 50 کاراکتر</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnerBirthdayPersian" class="form-label fw-bold">
                                                <i class="fas fa-calendar-alt"></i> تاریخ تولد متصرف
                                            </label>
                                            <input asp-for="Parcel.OwnerBirthdayPersian"
                                                   class="form-control persian-datepicker"
                                                   placeholder="مثال: 1365/04/15" />
                                            <span asp-validation-for="Parcel.OwnerBirthdayPersian" class="text-danger"></span>
                                            <small class="form-text text-muted">فرمت: yyyy/MM/dd</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipUnit" class="form-label fw-bold">
                                                <i class="fas fa-building"></i> نوع مالکیت
                                            </label>
                                            <select asp-for="Parcel.OwnershipUnit" class="form-control">
                                                <option value="">-- انتخاب کنید --</option>
                                                <option value="عرصه">عرصه</option>
                                                <option value="اعیان">اعیان</option>
                                                <option value="عرصه و اعیان">عرصه و اعیان</option>
                                            </select>
                                            <span asp-validation-for="Parcel.OwnershipUnit" class="text-danger"></span>
                                            <small class="form-text text-muted">نوع مالکیت را انتخاب کنید</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipQuantity" class="form-label fw-bold">
                                                <i class="fas fa-percent"></i> تعداد سهم مالکیت
                                            </label>
                                            <input asp-for="Parcel.OwnershipQuantity" class="form-control" step="0.01" />
                                            <span asp-validation-for="Parcel.OwnershipQuantity" class="text-danger"></span>
                                            <small class="form-text text-muted">عدد مثبت</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label asp-for="Parcel.OwnershipProof" class="form-label fw-bold">
                                                <i class="fas fa-gavel"></i> ادله و امارات مالکیت
                                            </label>
                                            <input asp-for="Parcel.OwnershipProof" class="form-control" />
                                            <span asp-validation-for="Parcel.OwnershipProof" class="text-danger"></span>
                                            <small class="form-text text-muted">حداکثر 500 کاراکتر</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ========================================== -->
                        <!-- بخش 5: اطلاعات بهره‌بردار -->
                        <!-- ========================================== -->
                        <div class="card mb-4 border-secondary">
                            <div class="card-header bg-secondary text-white">
