@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // ==========================================
            // نمایش خلاصه خطاهای اعتبارسنجی
            // ==========================================
            function showValidationSummary() {
                var errors = [];

                // جمع‌آوری خطاهای هر فیلد
                $('.field-validation-error').each(function() {
                    var errorText = $(this).text().trim();
                    if (errorText) {
                        errors.push(errorText);
                    }
                });

                var summary = $('#validationSummary');
                var list = $('#validationSummaryList');

                if (errors.length > 0) {
                    list.empty();
                    errors.forEach(function(error) {
                        list.append('<li>' + error + '</li>');
                    });
                    summary.show();
                } else {
                    summary.hide();
                }
            }

            // ==========================================
            // رویدادهای اعتبارسنجی
            // ==========================================
            $('form').on('submit', function() {
                // نمایش خلاصه خطاها بعد از 100 میلی‌ثانیه
                setTimeout(showValidationSummary, 100);
            });

            // بروزرسانی خلاصه خطاها بعد از اعتبارسنجی هر فیلد
            $('input, select, textarea').on('blur change', function() {
                setTimeout(showValidationSummary, 50);
            });

            // ==========================================
            // اعتبارسنجی تاریخ شمسی در سمت کلاینت
            // ==========================================
            $('.persian-datepicker').each(function() {
                $(this).on('blur', function() {
                    var value = $(this).val();
                    if (value && !isValidPersianDate(value)) {
                        $(this).addClass('is-invalid');
                        var errorSpan = $(this).siblings('.text-danger');
                        if (errorSpan.length === 0) {
                            $(this).after('<span class="text-danger field-validation-error">فرمت تاریخ باید yyyy/MM/dd باشد</span>');
                        } else {
                            errorSpan.text('فرمت تاریخ باید yyyy/MM/dd باشد');
                        }
                        showValidationSummary();
                    } else {
                        $(this).removeClass('is-invalid');
                        var errorSpan = $(this).siblings('.text-danger');
                        if (errorSpan.length > 0 && errorSpan.text().includes('yyyy/MM/dd')) {
                            errorSpan.text('');
                        }
                        showValidationSummary();
                    }
                });
            });

            // ==========================================
            // تابع اعتبارسنجی تاریخ شمسی
            // ==========================================
            function isValidPersianDate(dateString) {
                if (!dateString) return true;
                var regex = /^[1-4]\d{3}\/(0[1-9]|1[0-2])\/(0[1-9]|[12]\d|3[01])$/;
                return regex.test(dateString);
            }

            // ==========================================
            // نمایش اولیه خلاصه خطاها
            // ==========================================
            showValidationSummary();
        });
    </script>
}