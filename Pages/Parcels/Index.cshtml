@page
@using LandRegistrySystem.Models.Enums
@model LandRegistrySystem.Pages.Parcels.IndexModel
@{
    ViewData["Title"] = "مدیریت قطعات";
}

<div class="container-fluid mt-4" dir="rtl">
    <div class="row">
        <div class="col-12">
            <!-- ========================================== -->
            <!-- هدر و دکمه ثبت جدید -->
            <!-- ========================================== -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="fas fa-map"></i> مدیریت قطعات
                    <span class="badge bg-primary ms-2">@Model.TotalCount</span>
                </h1>
                <div>
                    <a asp-page="./Create" class="btn btn-success">
                        <i class="fas fa-plus"></i> ثبت قطعه جدید
                    </a>
                    <a asp-page="/Reports/OwnerParcelsReport" class="btn btn-info ms-2">
                        <i class="fas fa-print"></i> گزارش
                    </a>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- پیام‌ها -->
            <!-- ========================================== -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- ========================================== -->
            <!-- کارت جستجو -->
            <!-- ========================================== -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-search"></i> جستجوی پیشرفته</h5>
                </div>
                <div class="card-body">
                    <form method="get" class="row g-3" id="searchForm">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                                <input type="text" class="form-control"
                                       name="searchTerm" value="@Model.SearchTerm"
                                       placeholder="کد قطعه، استان، شهرستان..." />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search"></i> جستجو
                            </button>
                        </div>
                        <div class="col-md-3">
                            <a asp-page="./Index" class="btn btn-secondary w-100">
                                <i class="fas fa-undo"></i> نمایش همه
                            </a>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select" name="pageSize" onchange="this.form.submit()">
                                <option value="5" selected="@(Model.PageSize == 5)">۵</option>
                                <option value="10" selected="@(Model.PageSize == 10)">۱۰</option>
                                <option value="25" selected="@(Model.PageSize == 25)">۲۵</option>
                                <option value="50" selected="@(Model.PageSize == 50)">۵۰</option>
                                <option value="100" selected="@(Model.PageSize == 100)">۱۰۰</option>
                            </select>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ========================================== -->
            <!-- جدول قطعات -->
            <!-- ========================================== -->
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width:5%;">#</th>
                                    <th style="width:12%;">کد قطعه</th>
                                    <th style="width:15%;">نام فارسی</th>
                                    <th style="width:12%;">استان</th>
                                    <th style="width:12%;">شهرستان</th>
                                    <th style="width:10%;">مساحت (م²)</th>
                                    <th style="width:10%;">نوع مالکیت</th>
                                    <th style="width:10%;">نوع متصرف</th>
                                    <th style="width:14%;">عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Parcels != null && Model.Parcels.Any())
                                {
                                    int row = (Model.CurrentPage - 1) * Model.PageSize + 1;
                                    foreach (var item in Model.Parcels)
                                    {
                                        <tr>
                                            <td>@row</td>
                                            <td>
                                                <span class="badge bg-secondary">@item.ParcelCode</span>
                                            </td>
                                            <td>
                                                <span class="fw-bold">@item.PersianName</span>
                                                <br />
                                                <small class="text-muted">@item.EnglishName</small>
                                            </td>
                                            <td>@(item.Province ?? "-")</td>
                                            <td>@(item.Shahrestan ?? "-")</td>
                                            <td>@(item.Area?.ToString("N2") ?? "-")</td>
                                            <td>
                                                @if (item.OwnershipUnit != null)
                                                {
                                                    <span class="badge bg-info">
                                                        @(item.OwnershipUnit == OwnershipUnit.Land ? "عرصه" :
                                                          item.OwnershipUnit == OwnershipUnit.Building ? "اعیان" :
                                                          item.OwnershipUnit == OwnershipUnit.LandAndBuilding ? "عرصه و اعیان" : "-")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.OwnerType != null)
                                                {
                                                    <span class="badge @(item.OwnerType == OwnerType.Natural ? "bg-success" : "bg-warning")">
                                                        @(item.OwnerType == OwnerType.Natural ? "حقیقی" : "حقوقی")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-page="./Details" asp-route-id="@item.Id"
                                                       class="btn btn-info" title="مشاهده جزئیات">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-page="./Edit" asp-route-id="@item.Id"
                                                       class="btn btn-warning" title="ویرایش">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-danger"
                                                            onclick="confirmDelete(@item.Id)" title="حذف">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        row++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="9" class="text-center py-5">
                                            <i class="fas fa-info-circle fa-2x text-muted d-block mb-2"></i>
                                            <span class="text-muted">هیچ قطعه‌ای یافت نشد</span>
                                            <br />
                                            <a asp-page="./Create" class="btn btn-success btn-sm mt-2">
                                                <i class="fas fa-plus"></i> ثبت قطعه جدید
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ========================================== -->
                <!-- صفحه‌بندی -->
                <!-- ========================================== -->
                @if (Model.TotalPages > 1)
                {
                    <div class="card-footer bg-light">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted">
                                    نمایش @((Model.CurrentPage - 1) * Model.PageSize + 1) تا
                                    @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)
                                    از @Model.TotalCount
                                </span>
                            </div>
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-page="@(Model.CurrentPage - 1)"
                                           asp-route-searchTerm="@Model.SearchTerm"
                                           asp-route-pageSize="@Model.PageSize">
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </li>
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" asp-page="./Index"
                                               asp-route-page="@i"
                                               asp-route-searchTerm="@Model.SearchTerm"
                                               asp-route-pageSize="@Model.PageSize">
                                                @i
                                            </a>
                                        </li>
                                    }
                                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-page="@(Model.CurrentPage + 1)"
                                           asp-route-searchTerm="@Model.SearchTerm"
                                           asp-route-pageSize="@Model.PageSize">
                                            <i class="fas fa-chevron-left"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- مودال حذف -->
<!-- ========================================== -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> تأیید حذف</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <i class="fas fa-trash fa-3x text-danger mb-3"></i>
                <h5>آیا از حذف این قطعه اطمینان دارید؟</h5>
                <p class="text-muted">این عملیات غیرقابل بازگشت است و قطعه به صورت نرم حذف می‌شود.</p>
                <input type="hidden" id="deleteId" value="" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash"></i> تأیید حذف
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ==========================================
        // تابع نمایش مودال حذف
        // ==========================================
        function confirmDelete(id) {
            document.getElementById('deleteId').value = id;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        // ==========================================
        // تایید حذف
        // ==========================================
        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            var id = document.getElementById('deleteId').value;
            if (id) {
                // ارسال درخواست حذف
                fetch(`./Delete?id=${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(response => {
                    if (response.redirected) {
                        window.location.href = response.url;
                    } else {
                        window.location.reload();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    window.location.reload();
                });
            }
        });

        // ==========================================
        // تغییر اندازه صفحه
        // ==========================================
        document.querySelector('select[name="pageSize"]')?.addEventListener('change', function() {
            this.form.submit();
        });

        // ==========================================
        // جستجو با Enter
        // ==========================================
        document.querySelector('input[name="searchTerm"]')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                this.form.submit();
            }
        });

        // ==========================================
        // فعال‌سازی Tooltip
        // ==========================================
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}