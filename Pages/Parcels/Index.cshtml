@page
@model LandRegistrySystem.Pages.Parcels.IndexModel
@{
    ViewData["Title"] = "مدیریت قطعات";
}

<div class="container-fluid mt-4" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>مدیریت قطعات اراضی کشاورزی</h1>
                <a asp-page="./Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> ثبت قطعه جدید
                </a>
            </div>
            <!-- در Pages/Parcels/Index.cshtml -->
            <a asp-page="/Reports/OwnerParcelsReport" class="btn btn-primary">
                <i class="fas fa-file-alt"></i> گزارش قطعات متصرف
            </a>
            <!-- فرم جستجو -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">جستجوی پیشرفته</h5>
                </div>
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">جستجو</label>
                            <input type="text" class="form-control"
                                   name="searchTerm" value="@Model.SearchTerm"
                                   placeholder="کد قطعه، استان، شهرستان..." />
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-primary flex-fill">
                                <i class="fas fa-search"></i> جستجو
                            </button>
                            <a asp-page="./Index" class="btn btn-secondary flex-fill">
                                <i class="fas fa-undo"></i> نمایش همه
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- جدول داده‌ها -->
            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>ردیف</th>
                                    <th>کد قطعه</th>
                                    <th>نام فارسی</th>
                                    <th>استان</th>
                                    <th>شهرستان</th>
                                    <th>مساحت (م²)</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Parcels.Any())
                                {
                                    int row = (Model.CurrentPage - 1) * Model.PageSize + 1;
                                    foreach (var item in Model.Parcels)
                                    {
                                        <tr>
                                            <td>@row</td>
                                            <td>@item.ParcelCode</td>
                                            <td>@item.PersianName</td>
                                            <td>@item.ProvinceName</td>
                                            <td>@item.CountyName</td>
                                            <td>@item.Area?.ToString("N2")</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-page="./Details" asp-route-id="@item.Id"
                                                       class="btn btn-info">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-page="./Edit" asp-route-id="@item.Id"
                                                       class="btn btn-warning">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-page="./Delete" asp-route-id="@item.Id"
                                                       class="btn btn-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                        row++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4">
                                            <i class="fas fa-info-circle"></i>
                                            هیچ رکوردی یافت نشد
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- صفحه‌بندی -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                    <a class="page-link" asp-page="./Index"
                                       asp-route-page="@(Model.CurrentPage - 1)"
                                       asp-route-searchTerm="@Model.SearchTerm">
                                        قبلی
                                    </a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-page="./Index"
                                           asp-route-page="@i"
                                           asp-route-searchTerm="@Model.SearchTerm">
                                            @i
                                        </a>
                                    </li>
                                }
                                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                    <a class="page-link" asp-page="./Index"
                                       asp-route-page="@(Model.CurrentPage + 1)"
                                       asp-route-searchTerm="@Model.SearchTerm">
                                        بعدی
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>